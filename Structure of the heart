<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Biology: The Human Heart Anatomy</title>
    <style>
        :root {
            --bg-main: #0f172a;
            --card-bg: #1e293b;
            --blue-deox: #2563eb;
            --red-ox: #dc2626;
            --text-main: #f8fafc;
            --highlight: #22c55e;
            --valve-color: #e2e8f0;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h1 { margin-bottom: 5px; text-align: center; }
        .subtitle { color: #94a3b8; margin-bottom: 20px; text-align: center; }

        .main-layout {
            display: grid;
            grid-template-columns: 280px 1fr 320px;
            gap: 20px;
            max-width: 1300px;
            width: 100%;
            background-color: var(--card-bg);
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        /* Label Columns */
        .labels-column {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .category-group {
            background: #111827;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #334155;
        }

        .category-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            margin-bottom: 8px;
            font-weight: 700;
            border-bottom: 1px solid #334155;
            padding-bottom: 4px;
        }

        .label-btn {
            display: block;
            width: 100%;
            text-align: left;
            background: #1e293b;
            border: 1px solid #475569;
            color: #cbd5e1;
            padding: 8px 12px;
            margin: 4px 0;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .label-btn:hover {
            background: #334155;
            color: #fff;
        }

        .label-btn.active {
            background: var(--highlight);
            color: #000;
            font-weight: bold;
            border-color: #fff;
        }

        /* Center Canvas Panel */
        .canvas-panel {
            background: #090d16;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            padding: 10px;
            border: 1px solid #334155;
        }

        /* Display Panel */
        .info-panel {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .info-box {
            background: #090d16;
            padding: 20px;
            border-radius: 12px;
            border-top: 6px solid #64748b;
            min-height: 250px;
        }

        .info-box.deox { border-top-color: var(--blue-deox); }
        .info-box.ox { border-top-color: var(--red-ox); }
        .info-box.active-val { border-top-color: #eab308; }
        .info-box.active-struct { border-top-color: var(--highlight); }

        .info-box h3 { margin-top: 0; color: #fff; font-size: 1.3rem; }
        .info-box p { color: #cbd5e1; line-height: 1.5; font-size: 0.95rem; }

        /* SVG Heart Shapes styling */
        .clickable-part {
            cursor: pointer;
            transition: all 0.2s;
            stroke: #090d16;
            stroke-width: 2;
        }

        .clickable-part:hover {
            filter: brightness(1.2);
        }

        .clickable-part.selected {
            stroke: var(--highlight) !important;
            stroke-width: 4px !important;
            filter: brightness(1.3);
        }

        /* Flow Path Animations */
        .flow-line {
            fill: none;
            stroke-linecap: round;
            stroke-dasharray: 8, 12;
            stroke-width: 4;
            animation: moveBlood 1.5s linear infinite;
            display: none;
        }

        @keyframes moveBlood {
            to { stroke-dashoffset: -40; }
        }

        /* Muscle Beating Effect */
        .heart-muscle {
            animation: pulse 1s infinite ease-in-out;
            transform-origin: 250px 250px;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            30% { transform: scale(1.02); }
            45% { transform: scale(0.99); }
            60% { transform: scale(1.01); }
        }
    </style>
</head>
<body>

    <h1>The Anatomy & Physiology of the Human Heart</h1>
    <p class="subtitle">Click on any labels or visual components to inspect chambers, check valves, and track moving blood loops.</p>

    <div class="main-layout">
        
        <!-- Left Buttons Column -->
        <div class="labels-column">
            <div class="category-group">
                <div class="category-title">Heart Chambers</div>
                <button class="label-btn" data-target="ra">Right Atrium</button>
                <button class="label-btn" data-target="rv">Right Ventricle</button>
                <button class="label-btn" data-target="la">Left Atrium</button>
                <button class="label-btn" data-target="lv">Left Ventricle</button>
            </div>

            <div class="category-group">
                <div class="category-title">Heart Valves</div>
                <button class="label-btn" data-target="tv">Tricuspid Valve</button>
                <button class="label-btn" data-target="pv">Pulmonary Valve</button>
                <button class="label-btn" data-target="mv">Mitral Valve</button>
                <button class="label-btn" data-target="av">Aortic Valve</button>
            </div>
        </div>

        <!-- Center Interactive Graph Screen -->
        <div class="canvas-panel">
            <svg id="heartMap" viewBox="0 0 500 500" width="100%" height="450">
                
                <!-- BACKGROUND VESSEL LAYERS -->
                <g id="vessels">
                    <!-- Superior & Inferior Vena Cava -->
                    <path id="part-vc" class="clickable-part" fill="#1e40af" d="M 110,30 L 145,30 L 145,180 L 110,180 Z M 120,380 L 150,380 L 150,470 L 120,470 Z" />
                    <!-- Pulmonary Artery Branches -->
                    <path id="part-pa" class="clickable-part" fill="#2563eb" d="M 230,180 L 210,90 L 90,90 L 90,60 L 215,60 L 245,130 L 275,60 L 410,60 L 410,90 L 280,90 L 260,180 Z" />
                    <!-- Aorta Arch Structure -->
                    <path id="part-ao" class="clickable-part" fill="#991b1b" d="M 230,140 C 230,50 360,30 360,130 L 360,220 L 330,220 L 330,130 C 330,80 260,90 260,140 Z" />
                    <!-- Pulmonary Veins Entering Left Atrium -->
                    <path id="part-pvns" class="clickable-part" fill="#ef4444" d="M 70,180 L 110,180 L 110,205 L 70,205 Z M 390,180 L 430,180 L 430,205 L 390,205 Z" />
                </g>

                <!-- BEATING MUSCULAR INTERNAL HEART CHAMBERS -->
                <g id="muscleGroup" class="heart-muscle">
                    <!-- Right Atrium Interior Box Area -->
                    <path id="part-ra" class="clickable-part" fill="#3b82f6" d="M 125,180 C 90,210 100,280 160,280 L 190,220 Z" />
                    <!-- Left Atrium Interior Box Area -->
                    <path id="part-la" class="clickable-part" fill="#dc2626" d="M 375,180 C 410,210 400,280 340,280 L 310,220 Z" />
                    <!-- Right Ventricle -->
                    <path id="part-rv" class="clickable-part" fill="#1d4ed8" d="M 160,290 L 235,290 L 235,430 C 180,400 140,360 160,290 Z" />
                    <!-- Left Ventricle (Thicker Muscle Layout) -->
                    <path id="part-lv" class="clickable-part" fill="#b91c1c" d="M 265,290 L 340,290 C 360,360 320,400 265,430 Z" />
                    <!-- Central Septum Dividing Wall -->
                    <path id="part-sep" class="clickable-part" fill="#475569" d="M 235,260 L 265,260 L 265,445 L 235,430 Z" />

                    <!-- ONE-WAY VALVES LAYOUT -->
                    <!-- Tricuspid Valve -->
                    <line id="part-tv" class="clickable-part" x1="160" y1="285" x2="200" y2="285" stroke="var(--valve-color)" stroke-width="6" />
                    <!-- Mitral Valve -->
                    <line id="part-mv" class="clickable-part" x1="300" y1="285" x2="340" y2="285" stroke="var(--valve-color)" stroke-width="6" />
                    <!-- Pulmonary Valve -->
                    <line id="part-pv" class="clickable-part" x1="215" y1="160" x2="240" y2="165" stroke="var(--valve-color)" stroke-width="5" />
                    <!-- Aortic Valve -->
                    <line id="part-av" class="clickable-part" x1="250" y1="165" x2="275" y2="160" stroke="var(--valve-color)" stroke-width="5" />

                    <!-- NODE CONDUCTIONS (Electrical System overlay graphics) -->
                    <circle id="node-sa" class="clickable-part" cx="130" cy="195" r="7" fill="#eab308" stroke="#fff" stroke-width="1" />
                    <circle id="node-av" class="clickable-part" cx="210" cy="270" r="6" fill="#eab308" stroke="#fff" stroke-width="1" />
                    <path id="path-bundle" fill="none" stroke="#eab308" stroke-width="3" d="M 210,270 L 250,285 L 250,410" pointer-events="none" />
                </g>

                <!-- DYNAMIC BLOOD STREAM VECTOR OVERLAYS (Controlled via Interactive States) -->
                <!-- Deoxygenated streams -->
                <path id="flow-vc" class="flow-line" stroke="#60a5fa" d="M 125,30 L 125,230 L 175,340" />
